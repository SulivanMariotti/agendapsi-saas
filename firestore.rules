rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========= HELPERS =========
    function signedIn() { return request.auth != null; }
    function isAdmin()  { return signedIn() && request.auth.token.role == "admin"; }
    function isOwner(userId) { return signedIn() && request.auth.uid == userId; }

    // Paciente só pode atualizar (no próprio users/{uid}) campos estritamente necessários
    // para UX/contrato (evitar escalonamento e sequestro de agenda via troca de telefone/email).
    function allowedUserSelfUpdateKeys() {
      return ["lastSeen", "contractAcceptedVersion", "contractAcceptedAt"]; // mínimo
    }

    // ========= CONFIG (global) =========
    // Mantém o comportamento que você descreveu: leitura liberada, escrita só admin.
    match /config/{id} {
      allow read: if true;        // pode ler sem login
      allow write: if isAdmin();  // só admin altera
    }

    // ========= USERS (perfil) =========
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      // ✅ Segurança: criação do perfil é responsabilidade do Admin (whitelist).
      // Evita que um usuário crie users/{uid} forjado com phoneCanonical de terceiros.
      allow create: if isAdmin();

      // ✅ Segurança: o paciente não pode editar identidade (role/phone/email/status/etc.).
      // Apenas campos mínimos (lastSeen + aceite de contrato).
      allow update: if isAdmin()
        || (isOwner(userId)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(allowedUserSelfUpdateKeys())
        );
      allow delete: if isAdmin();
    }

    // ========= APPOINTMENTS =========
    match /appointments/{appointmentId} {
      // ✅ Segurança + constância:
      // O painel do paciente NÃO lê `appointments` direto do Firestore (client).
      // Ele usa API server-side (Admin SDK) para evitar `permission-denied` e reduzir superfície.
      allow read: if isAdmin();

      allow write: if isAdmin(); // só admin sobe agenda
    }

    // ========= PATIENT NOTES =========
    match /patient_notes/{noteId} {
      // Admin vê tudo
      // Paciente vê apenas o que for patientId == uid
      allow read: if isAdmin()
        || (signedIn() && resource.data.patientId == request.auth.uid);

      // Paciente pode criar nota apenas para si mesmo
      allow create: if signedIn() && request.resource.data.patientId == request.auth.uid;

      // ✅ Segurança: paciente pode editar apenas suas notas e NÃO pode trocar patientId no update.
      allow update: if isAdmin()
        || (signedIn()
          && resource.data.patientId == request.auth.uid
          && request.resource.data.patientId == request.auth.uid
        );

      // Paciente pode apagar apenas suas notas
      allow delete: if isAdmin()
        || (signedIn() && resource.data.patientId == request.auth.uid);
    }

    // ========= SUBSCRIBERS (whitelist/push) =========
    match /subscribers/{id} {
      // ✅ Segurança: paciente NÃO acessa subscribers no client.
      // Push é registrado via API server-side (Admin SDK).
      allow read, write: if isAdmin();
    }

    // ========= HISTORY =========
    match /history/{id} {
      allow read, write: if isAdmin();
    }

    // ========= ADMINS =========
    match /admins/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ========= AUDIT LOGS =========
    match /audit_logs/{id} {
      allow read, write: if isAdmin();
    }

    // fallback
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
