rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================================
    // AgendaPsi — Firestore Rules (multi-tenant + least privilege)
    //
    // Padrões oficiais:
    // - membership: tenants/{tenantId}/users/{uid}
    // - índice: userTenantIndex/{uid}
    //
    // Papéis:
    // - Admin global (claim): request.auth.token.role == "admin"
    // - Tenant roles (doc): owner | admin | professional
    //
    // Portal do Paciente (MVP):
    // - NÃO usa Firestore no client (somente APIs server-side com Admin SDK)
    // - Por segurança, tokens com role="patient" NÃO devem ter permissões aqui.
    // ==========================================================

    function signedIn() { return request.auth != null; }

    function isAdminClaim() {
      return signedIn() && request.auth.token.role == "admin";
    }

    function isPatientClaim() {
      return signedIn() && request.auth.token.role == "patient";
    }

    function memberDoc(tenantId) {
      return get(/databases/$(database)/documents/tenants/$(tenantId)/users/$(request.auth.uid));
    }

    function isTenantMemberActive(tenantId) {
      // paciente nunca é "membro" do tenant para fins de rules
      return signedIn()
        && !isPatientClaim()
        && memberDoc(tenantId).exists
        && memberDoc(tenantId).data.isActive != false;
    }

    function tenantRole(tenantId) {
      return isTenantMemberActive(tenantId) ? memberDoc(tenantId).data.role : "";
    }

    function isTenantProfessional(tenantId) {
      return isTenantMemberActive(tenantId)
        && (tenantRole(tenantId) in ["owner", "professional", "admin"]);
    }

    function isTenantAdmin(tenantId) {
      return isTenantMemberActive(tenantId)
        && (tenantRole(tenantId) in ["owner", "admin"]);
    }

    // ---------------------------
    // Global (público)
    // ---------------------------
    match /config/{id} {
      allow read: if true;
      allow write: if isAdminClaim();
    }

    // ---------------------------
    // Global (índices e sistema)
    // ---------------------------
    match /userTenantIndex/{uid} {
      allow read: if isAdminClaim() || (signedIn() && !isPatientClaim() && request.auth.uid == uid);
      allow write: if isAdminClaim();
    }

    match /_rate_limits/{id} {
      allow read, write: if false;
    }

    // ---------------------------
    // Tenant-scoped
    // ---------------------------
    match /tenants/{tenantId} {

      // Documento do tenant (metadados)
      allow read: if isAdminClaim() || isTenantMemberActive(tenantId);
      allow write: if isAdminClaim() || isTenantAdmin(tenantId);

      // Membership
      match /users/{uid} {
        allow read: if isAdminClaim()
          || (isTenantMemberActive(tenantId) && request.auth.uid == uid)
          || isTenantAdmin(tenantId);

        allow create, update, delete: if isAdminClaim() || isTenantAdmin(tenantId);
      }

      // Settings
      match /settings/{docId} {
        allow read: if isAdminClaim() || isTenantMemberActive(tenantId);
        allow write: if isAdminClaim() || isTenantAdmin(tenantId);
      }

      // Catálogo de códigos de ocorrência
      match /occurrenceCodes/{codeId} {
        allow read: if isAdminClaim() || isTenantMemberActive(tenantId);
        allow write: if isAdminClaim() || isTenantAdmin(tenantId);
      }

      match /whatsappTemplates/{templateId} {
        allow read: if isAdminClaim() || isTenantMemberActive(tenantId);
        allow write: if isAdminClaim() || isTenantAdmin(tenantId);
      }

      // Pacientes
      match /patients/{patientId} {
        allow read: if isAdminClaim() || isTenantMemberActive(tenantId);
        allow create, update: if isAdminClaim() || isTenantProfessional(tenantId);
        allow delete: if isAdminClaim() || isTenantAdmin(tenantId);

        // CLÍNICO (bloqueado para paciente)
        match /sessionEvolutions/{occurrenceId} {
          allow read, write: if isAdminClaim() || isTenantProfessional(tenantId);
        }

        match /occurrenceLogs/{logId} {
          allow read, write: if isAdminClaim() || isTenantProfessional(tenantId);
        }

        // Portal (MVP via API; staff permitido)
        match /patientNotes/{noteId} {
          allow read, write: if isAdminClaim() || isTenantProfessional(tenantId);
        }
      }

      // Séries e ocorrências
      match /appointmentSeries/{seriesId} {
        allow read, write: if isAdminClaim() || isTenantProfessional(tenantId);
      }

      match /appointmentOccurrences/{occurrenceId} {
        allow read, write: if isAdminClaim() || isTenantProfessional(tenantId);

        match /occurrenceLogs/{logId} {
          allow read, write: if isAdminClaim() || isTenantProfessional(tenantId);
        }
      }

      // Mapeamento interno do portal (server-only)
      match /patientsPortal/{patientId} {
        allow read, write: if isAdminClaim();
      }
    }

    // ---------------------------
    // Globais (admin-only)
    // ---------------------------
    match /patientAccessCodes/{code} {
      allow read, write: if isAdminClaim();
    }

    match /library_articles/{id} {
      allow read, write: if isAdminClaim();
    }
    match /library_categories/{id} {
      allow read, write: if isAdminClaim();
    }

    match /subscribers/{id} {
      allow read, write: if isAdminClaim();
    }

    // Coleções legadas / administrativas (bloqueadas exceto admin claim)
    match /users/{uid} { allow read, write: if isAdminClaim(); }
    match /history/{id} { allow read, write: if isAdminClaim(); }
    match /attendance_logs/{id} { allow read, write: if isAdminClaim(); }
    match /fat_nfse_invoices/{id} { allow read, write: if isAdminClaim(); }
    match /fat_nfse_import_batches/{id} { allow read, write: if isAdminClaim(); }
    match /admins/{id} { allow read: if isAdminClaim(); allow write: if false; }
    match /audit_logs/{id} { allow read, write: if isAdminClaim(); }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
