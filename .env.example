# ==============================
# Lembrete Psi — Exemplo de ENV
# Nunca envie .env* em zip e nunca versione.
# ==============================

# Admin (produção)
ADMIN_PASSWORD=

# Cron (produção) — segredo forte (32+ chars)
# Recomendado: lista (para rotação): SEGREDO_ATUAL,SEGREDO_NOVO
CRON_SECRETS=

# Compat (legado): ainda suportado se CRON_SECRETS estiver vazio
CRON_SECRET=

# Segurança: por padrão, NÃO permitir segredo em URL.
# Só habilite temporariamente se o seu scheduler não conseguir enviar headers.
ALLOW_CRON_QUERY_KEY=false

# Firebase Admin SDK (server) — use B64 do JSON do service account
FIREBASE_ADMIN_SERVICE_ACCOUNT_B64=

# Firebase client (público / Next.js)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Opcional: habilitar login inseguro por email (NÃO usar em produção)
NEXT_PUBLIC_ENABLE_PATIENT_EMAIL_LOGIN=false
ENABLE_INSECURE_PATIENT_EMAIL_LOGIN=false
